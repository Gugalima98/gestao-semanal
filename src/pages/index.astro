---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Login | Task Manager">
	<main class="flex-center login-page">
		<div class="glass login-card">
			<div class="header">
				<h1>Gestão Cliente</h1>
				<p>Acesse seu painel de acompanhamento</p>
			</div>
			
			<form class="login-form">
				<div class="input-group">
					<label for="password">Senha de Acesso</label>
					<input type="password" id="password" name="password" class="glass" placeholder="Digite sua senha..." required />
				</div>
				
				<p id="error-msg" class="error-msg"></p>

				<button type="submit" class="login-btn">Entrar</button>
			</form>
		</div>
	</main>
</Layout>

<style>
	.login-page {
		height: 100vh;
		padding: 1.5rem;
		box-sizing: border-box;
	}

	.login-card {
		padding: 3rem;
		width: 100%;
		max-width: 450px;
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	@media (max-width: 480px) {
		.login-card {
			padding: 1.5rem;
			gap: 1.5rem;
		}
	}

	.header h1 {
		font-size: 2rem;
		color: var(--primary);
	}

	.header p {
		color: var(--text-secondary);
		margin-top: 0.5rem;
	}

	.login-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.input-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		text-align: left;
	}

	label {
		font-size: 0.9rem;
		font-weight: 500;
	}

	input {
		padding: 1rem;
		color: white;
		border: 1px solid var(--border-glass);
		outline: none;
		background: rgba(255, 255, 255, 0.05);
		border-radius: 12px;
		width: 100%;
	}

	input:focus {
		border-color: var(--primary);
		box-shadow: 0 0 10px -5px var(--primary);
	}

	.error-msg {
		color: var(--danger);
		font-size: 0.85rem;
		min-height: 1.2rem;
	}

	.login-btn {
		background: var(--primary);
		color: white;
		border: none;
		padding: 1rem;
		border-radius: 12px;
		font-weight: 700;
		cursor: pointer;
		transition: var(--transition);
		width: 100%; /* Força preenchimento */
	}

	.login-btn:hover {
		transform: translateY(-2px);
		box-shadow: 0 10px 20px -5px var(--primary);
	}
</style>

<script>
	const form = document.querySelector('.login-form');
	const errorMsg = document.getElementById('error-msg');

	// Senhas definidas conforme solicitado
	const PASSWORDS = {
		ADMIN: '25939451@Gu',
		CLIENTE: 'luxuryproperties123'
	};

	form?.addEventListener('submit', (e) => {
		e.preventDefault();
		const password = (document.getElementById('password') as HTMLInputElement).value;
		
		if (password === PASSWORDS.ADMIN) {
			window.location.href = '/admin';
		} else if (password === PASSWORDS.CLIENTE) {
			window.location.href = '/cliente';
		} else {
			if (errorMsg) errorMsg.textContent = 'Senha incorreta. Tente novamente.';
		}
	});
</script>
